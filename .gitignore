# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Secrets / local config (never commit these)
.env
.env.*
*.key
*.pem
secrets.*

# Editor / OS cruft
.idea/
.vscode/
*.swp
.DS_Store

# Generated artifacts (the committed docs/equity_curve.png is the exception,
# force-added so the README renders an image)
*.log
